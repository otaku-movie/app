# Android 正式签名配置示例
# ---------------------------------------------------------
# 复制本文件为 android/key.properties（已在 .gitignore 中，请勿提交）
# 并填入你自己的 keystore 信息。
#
# 生成 keystore（在仓库根目录下执行）：
#   keytool -genkey -v -keystore android/keystore/otaku_movie.jks \
#     -alias otaku_movie -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile 路径相对 android/app 目录。
# ---------------------------------------------------------

storeFile=../keystore/otaku_movie.jks
storePassword=your_store_password_here
keyAlias=otaku_movie
keyPassword=your_key_password_here
