{
  // 使用 IntelliSense 了解相关属性。
  // 悬停以查看现有属性的描述。
  // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter: Debug (Dev)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "args": ["--flavor", "dev", "--dart-define-from-file=env/dev.json"]
    },
    {
      "name": "Flutter: Debug (Test)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "args": ["--flavor", "qa", "--dart-define-from-file=env/test.json"]
    },
    {
      "name": "Flutter: Debug (Preprod)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "args": ["--flavor", "prepord", "--dart-define-from-file=env/preprod.json"]
    },
    {
      "name": "Flutter: Debug (Prod)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "args": ["--flavor", "prod", "--dart-define-from-file=env/prod.json"]
    },
    {
      "name": "Flutter: Profile (Prod)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "args": ["--flavor", "prod", "--dart-define-from-file=env/prod.json"]
    },
    {
      "name": "Flutter: Release (Prod)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "args": ["--flavor", "prod", "--dart-define-from-file=env/prod.json"]
    },
    {
      "name": "Debug Node.js",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/lib/l10n/node/index.js", // 替换为你的 Node.js 主文件路径
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
